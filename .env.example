# ==========================================
# VARIABLES DE ENTORNO — BACKEND
# Copiar este archivo como .env y completar
# los valores desde Bitwarden > ILPEA-Credenciales
# ==========================================

# Modo de autenticacion (valores: firebase | development)
AUTH_MODE=firebase

# Ruta al archivo de clave de Firebase Admin SDK
# En desarrollo local: ./config/firebase-key.json
# IMPORTANTE: ese archivo NO debe subirse al repo, obtenerlo de Bitwarden
FIREBASE_KEY_PATH=./config/firebase-key.json

# URL del frontend (requerida para enlaces de restablecimiento de contraseña)
# Debe coincidir con un dominio autorizado en Firebase Auth > Settings > Authorized domains
FRONTEND_URL=http://localhost:5173

# ---- CORREO (Nodemailer) ----
MAIL_HOST=smtp.tuproveedor.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=tu-correo@dominio.com
MAIL_PASS=tu-contrasena-smtp
MAIL_FROM_EMAIL=no-reply@dominio.com
MAIL_FROM_NAME=ILPEA Transports

# ---- OPENAI ----
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx